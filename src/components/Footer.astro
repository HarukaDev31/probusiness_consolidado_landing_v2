---
import ResponsiveImage from './ResponsiveImage.astro';
import { asset } from '../lib/assets';

const footerStats = [
  { type: 'china', label: 'Sede propia en China' },
  { value: '+5000', label: 'Clientes satisfechos' },
  { value: '+10', label: 'Años de experiencia' },
];
---

<footer class="footer bg-probusiness-naranja-dark">
  <div class="site-container footer__inner">
    <a href="#inicio" class="footer-brand" aria-label="ProBusiness — Inicio">
      <ResponsiveImage
        src="/images/sections/12-footer/logo-large.svg"
        alt="probusiness"
        class="footer-brand__logo"
        loading="lazy"
        responsive={false}
      />
    </a>

    <div class="footer-stats">
      {
        footerStats.map((stat) => (
          <div class="footer-stat">
            {stat.type === 'ccl' ? (
              <ResponsiveImage
                src="/images/sections/12-footer/logo-ccl.svg"
                alt="CCL"
                class="footer-stat__logo footer-stat__logo--ccl"
                loading="lazy"
                responsive={false}
              />
            ) : stat.type === 'china' ? (
              <img
                src={asset('/images/sections/12-footer/icon-china.svg')}
                alt=""
                class="footer-stat__logo footer-stat__logo--china"
                aria-hidden="true"
                loading="lazy"
              />
            ) : (
              <p class="footer-stat__value font-sora">{stat.value}</p>
            )}
            <p class="footer-stat__label font-epilogue">{stat.label}</p>
          </div>
        ))
      }
    </div>

    <p class="footer-copy font-epilogue">2026, probusiness. Todos los derechos reservados</p>
  </div>
</footer>

<style>
  .footer__inner {
    display: grid;
    gap: clamp(1.75rem, calc(48 / 3973 * 100vw), 3rem);
    padding-block: clamp(2.5rem, calc(80 / 3973 * 100vw), 5rem) clamp(1.5rem, calc(40 / 3973 * 100vw), 2.5rem);
  }

  .footer-brand__logo,
  .footer-brand :global(.footer-brand__logo) {
    display: block;
    height: clamp(3.5rem, calc(460 / 3973 * 100vw), 11rem);
    width: auto;
    max-width: min(100%, calc(782 / 3973 * 100vw));
    object-fit: contain;
    }

  .footer-stats {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: clamp(1.25rem, calc(40 / 3973 * 100vw), 2.5rem);
  }

  @media (min-width: 1024px) {
    .footer__inner {
      grid-template-columns: minmax(0, 28%) 1fr;
      grid-template-areas:
        'brand stats'
        'copy copy';
      align-items: center;
    }

    .footer-brand {
      grid-area: brand;
    }

    .footer-stats {
      grid-area: stats;
      display: flex;
      justify-content: flex-end;
      flex-wrap: wrap;
      align-items: start;
      gap: clamp(1.5rem, calc(48 / 3973 * 100vw), 3.5rem);
    }

    .footer-copy {
      grid-area: copy;
    }
  }

  .footer-stat {
    display: grid;
    grid-template-rows: clamp(2rem, calc(166 / 3973 * 100vw), 5rem) auto;
    justify-items: center;
    align-content: start;
    gap: clamp(0.35rem, calc(12 / 3973 * 100vw), 0.75rem);
    text-align: center;
  }

  .footer-stat__logo--ccl,
  .footer-stat :global(.footer-stat__logo--ccl) {
    height: auto;
    max-height: clamp(2rem, calc(153 / 3973 * 100vw), 4.5rem);
    width: auto;
    align-self: center;
    filter: none;
  }

  .footer-stat__logo--china {
    height: auto;
    max-height: clamp(2rem, calc(207 / 3973 * 100vw), 5.5rem);
    width: clamp(2rem, calc(207 / 3973 * 100vw), 5.5rem);
    align-self: center;
    filter: brightness(0) invert(1);
  }

  .footer-stat__value {
    margin: 0;
    font-size: clamp(1.5rem, calc(120 / 3973 * 100vw), 3.5rem);
    font-weight: 500;
    line-height: 0.97;
    letter-spacing: -0.06em;
    color: #fff;
    min-height: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    align-self: center;
  }

  .footer-stat__label {
    margin: 0;
    font-size: clamp(0.55rem, calc(55 / 3973 * 100vw), 1.51rem);
    font-weight: 400;
    line-height: 0.98;
    letter-spacing: -0.01em;
    color: rgba(255, 255, 255, 0.95);
    max-width: 12ch;
    text-align: center;
    justify-self: center;
  }

  .footer-copy {
    margin: 0;
    text-align: center;
    font-size: clamp(0.625rem, calc(40 / 3973 * 100vw), 1.21rem);
    line-height: 0.98;
    letter-spacing: -0.01em;
    color: rgba(255, 255, 255, 0.8);
  }

  @media (max-width: 1023px) {
    .footer__inner {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      grid-template-areas:
        'stats stats'
        'brand copy';
      column-gap: clamp(0.75rem, 3.5vw, 1.25rem);
      row-gap: clamp(1.5rem, 5vw, 2rem);
    }

    .footer-brand {
      grid-area: brand;
      align-self: end;
    }

    .footer-brand__logo,
    .footer-brand :global(.footer-brand__logo) {
      height: clamp(2.5rem, 12vw, 3.5rem);
      max-width: 100%;
    }

    .footer-stats {
      grid-area: stats;
      align-items: start;
    }

    .footer-stat {
      grid-template-rows: clamp(2.75rem, 13vw, 3.5rem) auto;
      gap: clamp(0.35rem, 2vw, 0.5rem);
    }

    .footer-stat__logo--ccl,
    .footer-stat :global(.footer-stat__logo--ccl),
    .footer-stat__logo--china {
      max-height: clamp(2.5rem, 11vw, 3.25rem);
    }

    .footer-stat__logo--china {
      width: clamp(2.5rem, 11vw, 3.25rem);
    }

    .footer-stat__label {
      font-size: clamp(0.8rem, 3.6vw, 1rem);
      max-width: 11ch;
      text-align: center;
      justify-self: center;
    }

    .footer-copy {
      grid-area: copy;
      text-align: left;
      align-self: end;
    }
  }
</style>
