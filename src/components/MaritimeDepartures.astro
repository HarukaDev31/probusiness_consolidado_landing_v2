---
import ResponsiveImage from "./ResponsiveImage.astro";

const departures = [
  { day: "30", month: "MAYO" },
  { day: "15", month: "JUNIO" },
];
---

<section class="maritime section-gray site-section--lg">
  <div class="site-container maritime__container">
    <div class="maritime__grid">
      <div class="maritime__copy">
        <p class="maritime__route font-epilogue text-black/70">China – Perú</p>
        <h2 class="maritime__title section-title font-epilogue font-medium text-black">
          Próximas salidas<br />
          marítimas
        </h2>
        <p class="maritime__desc font-epilogue text-black">
          Reserva tu espacio en nuestro{" "}
          <span class="font-semibold">próximo envío.</span>
        </p>
      </div>

      <div class="maritime__stage" aria-hidden="true">
        <div class="maritime__dates">
          {
            departures.map((d) => (
              <div class="maritime__date gradient-dark-box">
                <p class="maritime__day font-sora font-medium text-white">
                  {d.day}
                </p>
                <p class="maritime__month font-sora font-medium uppercase text-white">
                  {d.month}
                </p>
              </div>
            ))
          }
        </div>

        <div class="maritime__visual-wrap">
          <div class="maritime__visual">
            <div class="maritime__visual-fade maritime__visual-fade--left"></div>
            <div class="maritime__visual-fade maritime__visual-fade--top"></div>
            <div
              class="maritime__visual-fade maritime__visual-fade--diagonal"
            ></div>
            <ResponsiveImage
              src="/images/sections/09-maritime/bg-ship.png"
              alt=""
              class="maritime__ship"
              sizes="(max-width: 1023px) 100vw, 55vw"
            />
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .maritime {
    overflow: hidden;
    padding-block: clamp(2rem, calc(140 / 3973 * 100vw), 5.5rem);
  }

  .maritime__container {
    position: relative;
  }

  .maritime__grid {
    --maritime-visual-h: clamp(8.5rem, calc(809 / 3973 * 100vw), 19.5rem);

    display: grid;
    align-items: start;
    gap: clamp(1rem, calc(34 / 3973 * 100vw), 2rem);
    position: relative;
  }

  @media (min-width: 1024px) {
    .maritime__grid {
      grid-template-columns: minmax(0, 42%) minmax(0, 58%);
      align-items: start;
      min-height: calc(
        var(--maritime-visual-h) + clamp(5.5rem, calc(294 / 3973 * 100vw), 10rem)
      );
    }
  }

  .maritime__copy {
    position: relative;
    z-index: 2;
    align-self: start;
  }

  .maritime__route {
    font-size: clamp(0.9375rem, calc(58 / 3973 * 100vw), 1.65rem);
    line-height: 1.2;
    text-transform: uppercase;
    letter-spacing: -0.06em;
  }

  .maritime__title {
    margin-top: 0.35rem;
    max-width: 14ch;
  }

  .maritime__desc {
    margin-top: clamp(0.75rem, calc(24 / 3973 * 100vw), 1.5rem);
    font-size: clamp(0.9375rem, calc(78 / 3973 * 100vw), 2.15rem);
    line-height: 0.98;
    letter-spacing: -0.01em;
    max-width: 22ch;
  }

  .maritime__stage {
    position: relative;
    display: flex;
    flex-direction: column;
    align-self: stretch;
    width: 100%;
    min-height: calc(
      var(--maritime-visual-h) + clamp(4rem, calc(224 / 3973 * 100vw), 7rem)
    );
  }

  @media (min-width: 1024px) {
    .maritime__stage {
      align-self: stretch;
      min-height: 100%;
      margin-right: calc(-1 * clamp(1.25rem, 7.55vw, 7.5rem));
    }
  }

  .maritime__visual-wrap {
    position: relative;
    width: 100%;
    margin-top: auto;
  }

  .maritime__visual {
    position: relative;
    overflow: hidden;
    height: var(--maritime-visual-h);
    border-radius: 0 0 var(--radius-ui) 0;
  }

  .maritime__dates {
    position: relative;
    z-index: 3;
    display: flex;
    flex-wrap: nowrap;
    gap: clamp(0.75rem, calc(62 / 3973 * 100vw), 1.5rem);
    padding-left: clamp(1rem, calc(545 / 3973 * 100vw), 8rem);
  }

  .maritime__date {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    border-radius: var(--radius-ui);
    padding: clamp(0.5rem, calc(20 / 3973 * 100vw), 1.25rem);
    text-align: center;
    flex-shrink: 0;
  }

  @media (min-width: 1024px) {
    .maritime__date {
      width: clamp(4.5rem, calc(406 / 3973 * 100vw), 12.5rem);
      min-height: clamp(3.75rem, calc(399 / 3973 * 100vw), 12rem);
    }
  }

  .maritime__day {
    font-size: clamp(1.25rem, calc(182 / 3973 * 100vw), 5.5rem);
    line-height: 0.9;
    letter-spacing: -0.09em;
    text-shadow: 0 4px 17.2px rgba(255, 255, 255, 0.25);
  }

  .maritime__month {
    margin-top: 0.25rem;
    font-size: clamp(0.6875rem, calc(77 / 3973 * 100vw), 2.25rem);
    line-height: 1.26;
    letter-spacing: 0.02em;
  }

  .maritime__visual-fade {
    position: absolute;
    z-index: 1;
    pointer-events: none;
  }

  .maritime__visual-fade--left {
    inset-block: 0;
    left: 0;
    width: 32%;
    background: linear-gradient(90deg, #f9f9f9 0%, rgba(249, 249, 249, 0) 100%);
  }

  .maritime__visual-fade--top {
    inset-inline: 0;
    top: 0;
    height: 22%;
    background: linear-gradient(180deg, #f9f9f9 0%, rgba(249, 249, 249, 0) 100%);
  }

  .maritime__visual-fade--diagonal {
    inset: 0;
    background: linear-gradient(
      118deg,
      #f9f9f9 0%,
      rgba(249, 249, 249, 0.85) 18%,
      rgba(249, 249, 249, 0) 42%
    );
  }

  .maritime__ship,
  .maritime__visual :global(.maritime__ship) {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center right;
  }

  @media (max-width: 1023px) {
    .maritime__grid {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: clamp(1.5rem, 5vw, 2.25rem);
    }

    .maritime__copy {
      width: 100%;
      max-width: 20rem;
      align-self: center;
      text-align: left;
    }

    .maritime__route {
      font-size: clamp(0.8rem, 3.2vw, 1rem);
      color: rgba(0, 0, 0, 0.7);
    }

    .maritime__title {
      max-width: none;
      margin-inline: 0;
      text-align: left;
    }

    .maritime__title br {
      display: block;
    }

    .maritime__desc {
      max-width: none;
      margin-inline: 0;
      font-size: clamp(1.05rem, 4.2vw, 1.35rem);
      line-height: 1.2;
      text-align: left;
    }

    .maritime__stage {
      display: contents;
    }

    .maritime__dates {
      order: 2;
      align-self: center;
      justify-content: center;
      width: 100%;
      max-width: 20rem;
      padding-left: 0;
      gap: clamp(0.65rem, 3vw, 1rem);
    }

    .maritime__date {
      flex: 0 0 auto;
      width: clamp(6.75rem, 28vw, 8.25rem);
      height: clamp(6.85rem, 27vw, 8.15rem);
      min-width: unset;
      min-height: unset;
      max-width: none;
      border-radius: var(--radius-ui);
      padding: 0.4rem 0.5rem;
      box-sizing: border-box;
      overflow: hidden;
    }

    .maritime__day {
      font-size: clamp(2.65rem, 12vw, 3.35rem);
      font-weight: 700;
      line-height: 0.88;
    }

    .maritime__month {
      font-size: clamp(0.8rem, 3.4vw, 1rem);
      margin-top: 0.1rem;
      line-height: 1.1;
    }

    .maritime__visual-wrap {
      order: 3;
      width: 100vw;
      max-width: 100vw;
      margin-top: clamp(0.5rem, 2vw, 1rem);
      margin-inline: calc(50% - 50vw);
    }

    .maritime__visual {
      height: clamp(12rem, 52vw, 18rem);
      border-radius: 0;
    }

    .maritime__visual-fade--left,
    .maritime__visual-fade--diagonal {
      display: none;
    }

    .maritime__visual-fade--top {
      height: 40%;
    }

    .maritime__ship,
    .maritime__visual :global(.maritime__ship) {
      object-position: center;
    }
  }

  @media (min-width: 1024px) {
    .maritime__title br {
      display: none;
    }
  }
</style>
