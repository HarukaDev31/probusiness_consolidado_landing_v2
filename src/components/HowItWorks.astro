---
import ResponsiveImage from "./ResponsiveImage.astro";
import { asset } from "../lib/assets";

const PATH_WIDTH = 3500.5;
const PATH_HEIGHT = 3452;

const rowAnchors = [
  { y: 41, xStart: 325, xEnd: 3082.5 },
  { y: 1792, xStart: 418, xEnd: 3082.5 },
  { y: 3411, xStart: 418, xEnd: 3140 },
];

function getStepCoords(row: number, col: number) {
  const anchor = rowAnchors[row - 1];
  const span = anchor.xEnd - anchor.xStart;
  const x = anchor.xStart + span * ((2 * col - 1) / 8);

  return {
    x: `${(x / PATH_WIDTH) * 100}%`,
    y: `${(anchor.y / PATH_HEIGHT) * 100}%`,
  };
}

const steps = [
  {
    num: 1,
    row: 1,
    col: 1,
    title: "Tú encuentras el producto que deseas",
    body: "Usa las plataformas como Alibaba, YiwuGo, Made-in-China, 1688 y otras páginas especializadas.",
    image: "/images/sections/05-how-it-works/step-01.png",
  },
  {
    num: 2,
    row: 1,
    col: 2,
    title: "Solicita el Invoice o cotización",
    body: "Tu proveedor te enviará la cotización para conocer el valor de la mercancía, luego compártenos el documento.",
    image: "/images/sections/05-how-it-works/step-02.png",
  },
  {
    num: 3,
    row: 1,
    col: 3,
    title: "Te realizamos una cotización inicial",
    body: "Con los costos estimados de importación para que evalúes tu inversión.",
    image: "/images/sections/05-how-it-works/step-03.png",
  },
  {
    num: 4,
    row: 1,
    col: 4,
    title: "Confirma tu participación",
    body: "En nuestra carga consolidada y asegura tu espacio en el próximo embarque.",
    image: "/images/sections/05-how-it-works/step-04.png",
  },
  {
    num: 5,
    row: 2,
    col: 4,
    title: "Confirma con tu proveedor la entrega",
    body: "Cuando tu mercadería llega a nuestro almacén podremos verificarlo.",
    image: "/images/sections/05-how-it-works/step-05.png",
  },
  {
    num: 6,
    row: 2,
    col: 3,
    title: "Recibimos tu mercancía",
    body: "En nuestro almacén en China y validamos que llegue correctamente antes de su envío.",
    image: "/images/sections/05-how-it-works/step-06.png",
  },
  {
    num: 7,
    row: 2,
    col: 2,
    title: "Consolidamos tu carga",
    body: "Junto con otras mercancías para optimizar costos y aprovechar mejor el espacio.",
    image: "/images/sections/05-how-it-works/step-07.png",
  },
  {
    num: 8,
    row: 2,
    col: 1,
    title: "Realizamos el embarque de tu carga",
    body: "Y monitoreamos el tránsito hasta su llegada al puerto de destino.",
    image: "/images/sections/05-how-it-works/step-08.png",
  },
  {
    num: 9,
    row: 3,
    col: 1,
    title: "Gestionamos los trámites aduaneros",
    body: "Incluyendo el aforo y el proceso de nacionalización de tu mercancía.",
    image: "/images/sections/05-how-it-works/step-09.png",
  },
  {
    num: 10,
    row: 3,
    col: 2,
    title: "Descargamos tu mercadería en Perú",
    body: "Verificamos que llegue en óptimas condiciones a nuestros almacenes.",
    image: "/images/sections/05-how-it-works/step-10.png",
  },
  {
    num: 11,
    row: 3,
    col: 3,
    title: "Coordinamos la entrega de tus productos",
    body: "Mediante recojo o envío hasta el destino que nos indiques.",
    image: "/images/sections/05-how-it-works/step-11.png",
  },
  {
    num: 12,
    row: 3,
    col: 4,
    title: "¡Listo! Tu importación fue todo un éxito.",
    body: "",
    image: "/images/sections/05-how-it-works/step-12.png",
    final: true,
  },
].map((step) => {
  const coords = getStepCoords(step.row, step.col);

  return {
    ...step,
    x: coords.x,
    y: coords.y,
  };
});

const phases = [
  {
    id: 1,
    label: "NEGOCIACIÓN",
    icon: "/images/sections/05-how-it-works/icon-phase-1.svg",
    heroImage: "/images/sections/05-how-it-works/step-01.png",
    modifier: "how-phase--1",
    stepNums: [1, 2, 3, 4],
  },
  {
    id: 2,
    label: "LOGÍSTICA",
    icon: "/images/sections/05-how-it-works/icon-phase-2.svg",
    heroImage: "/images/sections/05-how-it-works/step-06.png",
    modifier: "how-phase--2",
    stepNums: [5, 6, 7, 8],
  },
  {
    id: 3,
    label: "ENTREGA Y ADUANAS",
    icon: "/images/sections/05-how-it-works/icon-phase-3.svg",
    heroImage: "/images/sections/05-how-it-works/step-12.png",
    modifier: "how-phase--3",
    stepNums: [9, 10, 11, 12],
  },
];

const stepByNum = Object.fromEntries(steps.map((step) => [step.num, step]));
---

<section class="how section-white site-section--lg">
  <div class="site-container">
    <header class="how__heading">
      <div class="how__heading-row">
        <h2 class="how__title section-title font-epilogue font-medium text-black">
          <span class="how__title-line how__title-line--1">
            <img
              src={asset("/images/sections/03-what-is/icon-box.svg")}
              alt=""
              class="how__icon"
              aria-hidden="true"
            />
            <span class="how__title-line1-text">Así funciona</span>
          </span>
          <span class="how__title-bottom">
            <span class="how__title-line how__title-line--2">
              <span class="how__title-nuestro">nuestro</span>
              {' '}
              <span class="how__title-accent">servicio de</span>
            </span>
            <span class="how__title-line how__title-line--3">
              <span class="how__title-accent">importación</span>
              {' '}
              <span class="badge-pro--filled how__pro font-sora font-semibold">PRO</span>
            </span>
          </span>
        </h2>
      </div>
    </header>

    <div class="how-phases" aria-label="Fases del proceso de importación">
      {
        phases.map((phase, index) => (
          <details
            name="how-phases"
            class={`how-phase ${phase.modifier}`}
            open={index === 0}
          >
            <summary class="how-phase__header">
              <div class="how-phase__header-art" aria-hidden="true">
                <div class="how-phase__art-wrap">
                  <ResponsiveImage
                    src={phase.heroImage}
                    alt=""
                    class="how-phase__art"
                    loading="lazy"
                    sizes="8rem"
                    style="mix-blend-mode: multiply"
                  />
                </div>
              </div>
              <div class="how-phase__header-content">
                <div class="how-phase__header-main">
                  <span class="how-phase__icon-wrap" aria-hidden="true">
                    <img
                      src={asset(phase.icon)}
                      alt=""
                      class="how-phase__icon"
                    />
                  </span>
                  <span class="how-phase__labels">
                    <span class="how-phase__eyebrow font-epilogue font-normal text-black text-f-65">
                      FASE {phase.id}:
                    </span>
                    <span class="how-phase__name font-epilogue font-semibold text-black text-f-78">
                      {phase.label}
                    </span>
                  </span>
                </div>
                <span class="how-phase__chevron" aria-hidden="true">
                  <img
                    src={asset("/images/sections/05-how-it-works/chevron-down.svg")}
                    alt=""
                  />
                </span>
              </div>
            </summary>
            <div class="how-phase__panel">
              <div class="how-phase__panel-inner">
              <ol class="how-phase__timeline">
                {
                  phase.stepNums.map((num) => {
                    const step = stepByNum[num];

                    return (
                      <li class="how-phase__item">
                        <span class="how-phase__badge-wrap">
                          <span class="how-phase__badge-glow" aria-hidden="true"></span>
                          <span class="step-badge how-phase__badge font-sora font-medium">{num}</span>
                        </span>
                        <div class="how-phase__copy">
                          {step.final ? (
                            <h3 class="how-phase__title how-phase__title--final font-epilogue text-black text-f-65">
                              <span class="font-semibold">¡Listo!</span>
                              <span class="font-medium"> Tu importación fue todo un éxito.</span>
                            </h3>
                          ) : (
                            <>
                              <h3 class="how-phase__title font-epilogue font-semibold text-black text-f-65">
                                {step.title}
                              </h3>
                              {step.body ? (
                                <p class="how-phase__body font-epilogue font-normal text-black text-f-65">
                                  {step.body}
                                </p>
                              ) : null}
                            </>
                          )}
                        </div>
                      </li>
                    );
                  })
                }
              </ol>
              </div>
            </div>
          </details>
        ))
      }
    </div>

    <div class="how-it-works">
      <div class="how-it-works__canvas">
        <img
          src={asset("/images/sections/05-how-it-works/path.svg")}
          alt=""
          class="how-it-works__path"
          aria-hidden="true"
        />

        <ol class="how-it-works__list">
        {
          steps.map((step) => (
            <li
              class="how-it-works__step"
              style={`--step-x: ${step.x}; --step-y: ${step.y};`}
              data-step={step.num}
            >
              <ResponsiveImage
                src={step.image}
                alt=""
                class="how-it-works__thumb"
                sizes="(max-width: 767px) 40vw, 11rem"
              />
              <span class="step-badge how-it-works__badge">{step.num}</span>
              <div class="how-it-works__text">
                {step.final ? (
                  <h3 class="how-it-works__step-title how-it-works__step-title--final font-epilogue text-black">
                    <span class="font-semibold">¡Listo!</span>
                    <span class="font-medium"> Tu importación fue todo un éxito.</span>
                  </h3>
                ) : (
                  <>
                    <h3 class="how-it-works__step-title font-epilogue font-semibold text-black">
                      {step.title}
                    </h3>
                    {step.body ? (
                      <p class="how-it-works__step-body font-epilogue font-normal text-black">
                        {step.body}
                      </p>
                    ) : null}
                  </>
                )}
              </div>
            </li>
          ))
        }
      </ol>
      </div>
    </div>

   
  </div>
</section>

<style>
  .how__heading {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    position: relative;
    z-index: 2;
    margin-bottom: clamp(2rem, calc(64 / 3973 * 100vw), 4rem);
  }

  .how__heading-row {
    display: flex;
    flex-direction: row;
    align-items: center;
    justify-content: center;
    gap: clamp(0.125rem, calc(4 / 3973 * 100vw), 0.25rem);
  }

  .how__title-line--1 {
    display: inline-flex;
    align-items: center;
    gap: clamp(0.125rem, calc(4 / 3973 * 100vw), 0.25rem);
  }

  .how__icon {
    width: clamp(3rem, calc(271 / 3973 * 100vw), 10.5rem);
    height: auto;
    aspect-ratio: 270.775 / 287.874;
    flex-shrink: 0;
  }

  .how__title-line1-text {
    display: inline;
  }

  .how__title {
    text-align: center;
  }

  .how__title-accent {
    font-weight: 600;
    color: var(--color-probusiness-naranja);
  }

  @media (min-width: 1024px) {
    .how__heading-row {
      gap: clamp(1rem, calc(40 / 3973 * 100vw), 2rem);
    }

    .how__title-line--1 {
      gap: clamp(1rem, calc(40 / 3973 * 100vw), 2rem);
    }

    .how__title {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 0.05em;
      text-align: center;
    }

    .how__title-line--1::after {
      content: ' nuestro';
    }

    .how__title-bottom {
      display: inline-flex;
      flex-wrap: wrap;
      align-items: baseline;
      justify-content: center;
      gap: 0.28em;
    }

    .how__title-line--2,
    .how__title-line--3 {
      display: inline-flex;
      align-items: baseline;
      gap: 0.28em;
    }

    .how__title-nuestro {
      display: none;
    }
  }

  .how__pro {
    display: inline-flex;
    align-items: center;
    flex-shrink: 0;
    font-size: clamp(0.875rem, calc(96 / 3973 * 100vw), 2.9rem);
    padding: 0.1em 0.45em;
    border-radius: var(--radius-ui);
    color: #fff;
  }

  .how__coverage {
    margin-top: clamp(2rem, calc(80 / 3973 * 100vw), 4rem);
    text-align: center;
    font-size: clamp(0.875rem, calc(65 / 3973 * 100vw), 1.96rem);
    line-height: 1.2;
  }

  .how__coverage-label {
    font-weight: 500;
  }

  .how__coverage-value {
    font-weight: 600;
  }

  .how-it-works {
    position: relative;
    width: 100%;
    margin-inline: auto;
    display: none;
  }

  .how-phases {
    --phase-radius: var(--radius-ui);
    --phase-header-h: clamp(5.5rem, calc(388 / 3973 * 100vw), 12.2rem);
    --phase-icon-circle: clamp(4.5rem, calc(270 / 3973 * 100vw), 8.4rem);
    --phase-badge-outer: clamp(3.5rem, calc(240 / 3973 * 100vw), 6rem);
    --phase-badge-inner: clamp(2.6rem, calc(178 / 3973 * 100vw), 4.45rem);
    --phase-step-gap: clamp(1.75rem, calc(631 / 3973 * 100vw), 4rem);

    width: 90%;
    max-width: 90%;
    margin-inline: auto;
    display: flex;
    flex-direction: column;
    gap: clamp(0.65rem, calc(85 / 3973 * 100vw), 1.5rem);
  }

  .how-phase {
    border-radius: var(--phase-radius);
    overflow: hidden;
    background: #fef1e9;
    transition: background-color 0.35s ease;
  }

  .how-phase--1:not([open]) {
    background: #fcdcd1;
  }

  .how-phase--2:not([open]) {
    background: #fce5d3;
  }

  .how-phase--3:not([open]) {
    background: rgba(255, 84, 16, 0.59);
  }

  .how-phase[open] {
    background: #fef1e9;
  }

  .how-phase__header {
    position: relative;
    min-height: var(--phase-header-h);
    list-style: none;
    cursor: pointer;
    overflow: hidden;
    transition: border-radius 0.35s ease;
  }

  .how-phase__header::-webkit-details-marker {
    display: none;
  }

  .how-phase__header-art {
    position: absolute;
    inset: 0;
    z-index: 0;
    display: flex;
    align-items: center;
    justify-content: flex-end;
    overflow: hidden;
    pointer-events: none;
    border-radius: var(--phase-radius) var(--phase-radius) 0 0;
    visibility: hidden;
  }

  .how-phase[open] .how-phase__header-art {
    visibility: visible;
  }

  .how-phase__art-wrap {
    display: flex;
    align-items: center;
    justify-content: flex-end;
    width: clamp(5rem, 32%, 10rem);
    max-height: 85%;
    margin-right: 0;
    flex-shrink: 0;
    isolation: isolate;
  }

  .how-phase--1[open] .how-phase__art-wrap,
  .how-phase--1[open] .how-phase__art-wrap :global(picture) {
    background-color: #fcdcd1;
  }

  .how-phase--2[open] .how-phase__art-wrap,
  .how-phase--2[open] .how-phase__art-wrap :global(picture) {
    background-color: #fce5d3;
  }

  .how-phase--3[open] .how-phase__art-wrap,
  .how-phase--3[open] .how-phase__art-wrap :global(picture) {
    background-color: #ff9469;
  }

  .how-phase__art-wrap :global(picture),
  .how-phase__art-wrap :global(img.how-phase__art) {
    display: block;
    width: 100%;
    height: auto;
    max-height: 85%;
    margin: 0;
    padding: 0;
    object-fit: contain;
    object-position: right center;
  }

  .how-phase__art-wrap :global(img.how-phase__art) {
    mix-blend-mode: multiply;
  }

  .how-phase__header-content {
    position: relative;
    z-index: 1;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: clamp(0.75rem, calc(24 / 3973 * 100vw), 1.25rem);
    min-height: var(--phase-header-h);
    padding: clamp(0.85rem, calc(80 / 3973 * 100vw), 1.75rem)
      clamp(1rem, calc(120 / 3973 * 100vw), 2.25rem);
  }

  .how-phase:not([open]) .how-phase__header-content {
    justify-content: space-between;
  }

  .how-phase[open] .how-phase__header-content {
    justify-content: flex-start;
    padding-right: clamp(1rem, calc(72 / 3973 * 100vw), 1.85rem);
  }

  .how-phase__header-main {
    display: flex;
    align-items: center;
    gap: clamp(0.5rem, calc(70 / 3973 * 100vw), 1.75rem);
    min-width: 0;
    flex: 1;
  }

  .how-phase[open] .how-phase__header-main {
    flex: 1;
    max-width: 52%;
  }

  .how-phase__icon-wrap {
    display: flex;
    align-items: center;
    justify-content: center;
    width: var(--phase-icon-circle);
    height: var(--phase-icon-circle);
    border-radius: 50%;
    background: #fff;
    flex-shrink: 0;
  }

  .how-phase__icon {
    display: block;
    width: auto;
    height: auto;
    max-width: 58%;
    max-height: 58%;
    aspect-ratio: 1;
    object-fit: contain;
    flex-shrink: 0;
  }

  .how-phase--2 .how-phase__icon {
    max-width: 55%;
    max-height: 55%;
  }

  .how-phase--3 .how-phase__icon {
    max-width: 44%;
    max-height: 44%;
  }

  .how-phase__labels {
    display: flex;
    flex-direction: column;
    gap: 0.05em;
    min-width: 0;
  }

  .how-phase__eyebrow {
    line-height: 1.11;
    letter-spacing: -0.01em;
  }

  .how-phase__name {
    line-height: 1.11;
    letter-spacing: -0.02em;
  }

  .how-phase__chevron {
    display: flex;
    align-items: center;
    justify-content: center;
    width: clamp(1.1rem, calc(42 / 3973 * 100vw), 1.65rem);
    height: auto;
    flex-shrink: 0;
    color: #000;
    opacity: 1;
    transform: rotate(0deg);
    transition:
      opacity 0.25s ease,
      transform 0.25s ease,
      visibility 0.25s ease;
  }

  .how-phase__chevron img {
    display: block;
    width: 100%;
    height: auto;
    aspect-ratio: 84 / 48;
    object-fit: contain;
  }

  .how-phase:not([open]) .how-phase__chevron {
    display: flex;
    opacity: 1;
    visibility: visible;
  }

  .how-phase[open] .how-phase__chevron {
    display: none;
    opacity: 0;
    visibility: hidden;
  }

  .how-phase--1 .how-phase__header {
    background: #fcdcd1;
  }

  .how-phase--2 .how-phase__header {
    background: #fce5d3;
  }

  .how-phase--3 .how-phase__header {
    background: rgba(255, 84, 16, 0.59);
  }

  .how-phase:not([open]) .how-phase__header {
    background: transparent;
  }

  .how-phase:not([open]) .how-phase__header {
    border-radius: var(--phase-radius);
  }

  .how-phase[open] .how-phase__header {
    border-radius: var(--phase-radius) var(--phase-radius) 0 0;
  }

  .how-phase__panel {
    display: grid;
    grid-template-rows: 0fr;
    background: #fef1e9;
    border-radius: 0 0 var(--phase-radius) var(--phase-radius);
    transition: grid-template-rows 0.45s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .how-phase[open] .how-phase__panel {
    grid-template-rows: 1fr;
  }

  .how-phase__panel-inner {
    overflow: hidden;
    min-height: 0;
    position: relative;
    padding: 0
      clamp(1rem, calc(72 / 3973 * 100vw), 1.85rem)
      0
      clamp(1rem, calc(130 / 3973 * 100vw), 2.85rem);
    transition: padding 0.45s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .how-phase[open] .how-phase__panel-inner {
    padding: clamp(1rem, calc(72 / 3973 * 100vw), 1.85rem)
      clamp(1rem, calc(72 / 3973 * 100vw), 1.85rem)
      clamp(1.25rem, calc(88 / 3973 * 100vw), 2.35rem)
      clamp(1rem, calc(130 / 3973 * 100vw), 2.85rem);
  }

  .how-phase__timeline {
    list-style: none;
    margin: 0;
    padding: 0;
    position: relative;
    display: flex;
    flex-direction: column;
    gap: var(--phase-step-gap);
  }

  .how-phase__timeline::before {
    content: "";
    position: absolute;
    left: calc(var(--phase-badge-outer) / 2);
    top: calc(var(--phase-badge-outer) / 2);
    bottom: calc(var(--phase-badge-outer) / 2);
    width: clamp(6px, calc(13 / 3973 * 100vw), 13px);
    transform: translateX(-50%);
    background: linear-gradient(180deg, #ff5410 0%, #ff733b 75.48%);
    border-radius: var(--radius-ui);
    z-index: 0;
    pointer-events: none;
  }

  .how-phase__item {
    display: grid;
    grid-template-columns: var(--phase-badge-outer) 1fr;
    gap: clamp(0.35rem, calc(48 / 3973 * 100vw), 1.25rem);
    align-items: start;
    position: relative;
  }

  .how-phase__badge-wrap {
    position: relative;
    z-index: 1;
    width: var(--phase-badge-outer);
    height: var(--phase-badge-outer);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .how-phase__badge-glow {
    position: absolute;
    inset: 0;
    border-radius: clamp(2rem, calc(155 / 3973 * 100vw), 9.7rem);
    background: linear-gradient(
      90deg,
      rgba(255, 84, 16, 0.36) 0%,
      rgba(255, 115, 59, 0.36) 46.49%,
      rgba(255, 84, 16, 0.36) 100%
    );
    box-shadow: 0 1px 18.4px 12px rgba(255, 106, 41, 0.18);
    border: 0.5px solid transparent;
  }

  .how-phase__badge.step-badge {
    position: relative;
    z-index: 1;
