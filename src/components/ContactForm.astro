---
import ResponsiveImage from './ResponsiveImage.astro';
import { asset } from '../lib/assets';
import { leadFormConfig } from '../lib/leadForm';

const { apiUrl, formToken, campaignCode, graciasPath } = leadFormConfig;

const trustItems = [
  'Respaldado por la CCL',
  '+5 000 clientes satisfechos',
  'Sede propia en China',
  '+10 años de experiencia',
];
---

<section id="contacto" class="contact section-white site-section--lg">
  <div class="site-container">
    <div class="contact__panel radius-figma overflow-hidden border-2 border-[#fa4700] bg-white">
      <div class="contact__grid">
        <div class="contact__visual">
          <ResponsiveImage
            src="/images/sections/10-contact/photo.png"
            alt="Asesor ProBusiness"
            class="contact__photo"
            sizes="(max-width: 1023px) 100vw, 42vw"
          />
          <img src={asset('/images/sections/10-contact/puntos.svg')} alt="" class="contact__puntos" aria-hidden="true" />
        </div>

        <div class="contact__form-wrap">
          <h2 class="contact__title font-epilogue font-medium text-black">Cuéntanos si estás listo para importar</h2>
          <p class="contact__subtitle font-epilogue text-black/85">Estamos listos para traer tu carga sin complicaciones.</p>

          <form
            id="contact-form"
            class="contact__form"
            novalidate
            data-api-url={apiUrl}
            data-form-token={formToken}
            data-campaign-code={campaignCode}
            data-gracias-path={graciasPath}
          >
            <div class="contact__field" data-field="nombre">
              <label for="nombre" class="contact__label">Nombre Completo</label>
              <input type="text" id="nombre" name="nombre" placeholder="e.g José Gutiérrez" class="contact__input" required />
            </div>

            <div class="contact__field" data-field="whatsapp">
              <label for="whatsapp" class="contact__label">Número de WhatsApp</label>
              <input type="tel" id="whatsapp" name="whatsapp" placeholder="999 999 999" class="contact__input" required />
            </div>

            <div class="contact__field" data-field="proveedor_china">
              <label for="proveedor" class="contact__label">¿Ya tienes tu proveedor en China?</label>
              <div class="contact__select-wrap">
                <select id="proveedor" name="proveedor_china" class="contact__input contact__select" required>
                  <option value="" disabled selected>Selecciona una opción</option>
                  <option value="si">Sí, ya tengo proveedor</option>
                  <option value="no">No, necesito ayuda</option>
                  <option value="buscando">Estoy buscando proveedor</option>
                </select>
                <img src={asset('/images/sections/10-contact/chevron.svg')} alt="" class="contact__chevron" aria-hidden="true" />
              </div>
            </div>

            <button type="submit" class="contact__submit btn-primary font-epilogue font-bold text-white">
              Quiero importar
            </button>
            <p id="form-feedback" class="contact__feedback font-epilogue"></p>
          </form>

          <ul class="contact__trust">
            {
              trustItems.map((item) => (
                <li class="contact__trust-item font-epilogue">
                  <img src={asset('/images/sections/10-contact/icon-check.svg')} alt="" class="contact__trust-icon" aria-hidden="true" />
                  {item}
                </li>
              ))
            }
          </ul>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .contact__grid {
    display: grid;
    grid-template-columns: 1fr;
  }

  @media (min-width: 1024px) {
    .contact__grid {
      grid-template-columns: minmax(0, 42%) minmax(0, 58%);
    }
  }

  .contact__visual {
    position: relative;
    display: none;
    min-height: clamp(20rem, calc(1134 / 3973 * 100vw), 36rem);
    background: #f5f5f5;
  }

  @media (min-width: 1024px) {
    .contact__visual {
      display: block;
    }
  }

  .contact__photo,
  .contact__visual :global(.contact__photo) {
    position: absolute;
    inset: 0;
    width: 122%;
    height: 124%;
    left: -16%;
    top: 0;
    object-fit: cover;
    object-position: top center;
  }

  .contact__puntos {
    position: absolute;
    bottom: 0;
    right: 0;
    width: 66%;
    opacity: 0.4;
    pointer-events: none;
  }

  .contact__form-wrap {
    padding: clamp(1.25rem, calc(48 / 3973 * 100vw), 3rem);
  }

  .contact__title {
    font-size: clamp(1.15rem, calc(110 / 3973 * 100vw), 3.3rem);
    line-height: 1.05;
    letter-spacing: -0.03em;
    max-width: 16ch;
  }

  .contact__subtitle {
    margin-top: clamp(0.5rem, calc(16 / 3973 * 100vw), 1rem);
    font-size: clamp(0.875rem, calc(65 / 3973 * 100vw), 1.96rem);
    line-height: 1.35;
    max-width: 24ch;
  }

  .contact__form {
    margin-top: clamp(1.25rem, calc(40 / 3973 * 100vw), 2rem);
    display: flex;
    flex-direction: column;
    gap: clamp(1rem, calc(32 / 3973 * 100vw), 1.75rem);
  }

  .contact__label {
    display: block;
    font-family: var(--font-epilogue);
    font-size: clamp(0.75rem, calc(40 / 3973 * 100vw), 1.21rem);
    font-weight: 500;
    color: #000;
    margin-bottom: 0.35rem;
  }

  .contact__input {
    width: 100%;
    border-radius: clamp(10px, calc(12 / 3973 * 100vw), 12px);
    border: 1px solid #ccc;
    background: #fff;
    padding: clamp(0.75rem, calc(24 / 3973 * 100vw), 1.25rem) clamp(0.875rem, calc(28 / 3973 * 100vw), 1.5rem);
    font-family: var(--font-epilogue);
    font-size: clamp(0.875rem, calc(48 / 3973 * 100vw), 1.45rem);
    color: #000;
    outline: none;
  }

  .contact__input:focus {
    border-color: var(--color-probusiness-naranja);
  }

  .contact__select-wrap {
    position: relative;
  }

  .contact__select {
    appearance: none;
    padding-right: 2.5rem;
  }

  .contact__chevron {
    position: absolute;
    right: 1rem;
    top: 50%;
    width: clamp(0.75rem, calc(32 / 3973 * 100vw), 1.25rem);
    transform: translateY(-50%);
    pointer-events: none;
  }

  .contact__submit {
    width: 100%;
    font-size: clamp(1rem, calc(96 / 3973 * 100vw), 2.9rem);
    line-height: 1.26;
    padding-block: clamp(0.85rem, calc(44 / 3973 * 100vw), 1.75rem);
  }

  .contact__feedback {
    text-align: center;
    font-size: 0.875rem;
    color: rgba(0, 0, 0, 0.6);
    margin: 0;
  }

  .contact__trust {
    display: grid;
    gap: 0.65rem;
    margin-top: clamp(1.25rem, calc(40 / 3973 * 100vw), 2rem);
    padding: 0;
    list-style: none;
  }

  @media (min-width: 640px) {
    .contact__trust {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  .contact__trust-item {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: clamp(0.75rem, calc(40 / 3973 * 100vw), 1.21rem);
    color: #000;
  }

  .contact__trust-icon {
    width: clamp(1rem, calc(40 / 3973 * 100vw), 1.5rem);
    height: clamp(1rem, calc(40 / 3973 * 100vw), 1.5rem);
    flex-shrink: 0;
  }
</style>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement | null;
  const feedback = document.getElementById('form-feedback');

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const apiUrl = form.dataset.apiUrl;
    const formToken = form.dataset.formToken;
    const campaignCode = form.dataset.campaignCode;
    const graciasPath = form.dataset.graciasPath ?? '/gracias';

    if (!apiUrl) {
      if (feedback) feedback.textContent = 'Formulario en modo demo — configura PUBLIC_LANDING_CONSOLIDADO_API_URL en .env';
      return;
    }

    const data = new FormData(form);
    try {
      const res = await fetch(apiUrl, {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          ...(formToken ? { 'X-Form-Token': formToken } : {}),
        },
        body: JSON.stringify({
          nombre: data.get('nombre'),
          whatsapp: data.get('whatsapp'),
          proveedor_china: data.get('proveedor_china'),
          campaign_code: campaignCode,
        }),
      });
      if (!res.ok) throw new Error();
      window.location.href = graciasPath;
    } catch {
      if (feedback) feedback.textContent = 'No pudimos enviar tu solicitud. Intenta de nuevo.';
    }
  });
</script>
