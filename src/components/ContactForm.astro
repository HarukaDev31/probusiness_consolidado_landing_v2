---
import { asset, responsiveImage } from '../lib/assets';
import { leadFormConfig } from '../lib/leadForm';

const { apiUrl, formToken, campaignCode, graciasPath } = leadFormConfig;

const contactPhotoDesktop = responsiveImage('/images/sections/10-contact/photo.png', {
  sizes: '(max-width: 1023px) 0px, 42vw',
});
const contactPhotoMobile = responsiveImage('/images/sections/10-contact/photo-mobile.png', {
  sizes: '(max-width: 1023px) 100vw, 0px',
});

const trustItems = [
  'Respaldado por la CCL',
  '+5 000 clientes satisfechos',
  'Sede propia en China',
  '+10 años de experiencia',
];
---

<section id="contacto" class="contact section-white site-section--lg">
  <div class="site-container">
    <div class="contact__shell">
      <div class="contact__panel overflow-hidden">
        <div class="contact__body">
          <div class="contact__grid">
          <div class="contact__visual">
            <picture class="contact__picture">
              <source
                media="(max-width: 1023px)"
                type="image/webp"
                srcset={contactPhotoMobile.webpSrcset}
                sizes={contactPhotoMobile.sizes}
              />
              <source
                type="image/webp"
                srcset={contactPhotoDesktop.webpSrcset}
                sizes={contactPhotoDesktop.sizes}
              />
              <img
                src={contactPhotoDesktop.fallback}
                alt="Asesor ProBusiness"
                class="contact__photo"
                loading="lazy"
                decoding="async"
              />
            </picture>
            <div class="contact__visual-fade" aria-hidden="true"></div>
          </div>

          <div class="contact__copy">
            <h2 class="contact__title section-title font-epilogue font-medium text-black">
              Cuéntanos si 
              <br />
              estás{' '}
              <span class="contact__title-accent font-semibold text-probusiness-naranja">
                listo para importar
              </span>
            </h2>
            <p class="contact__subtitle font-epilogue text-black">
              Estamos listos para traer tu carga sin complicaciones.
            </p>
          </div>

          <div class="contact__form-wrap">
            <form
              id="contact-form"
              class="contact__form"
              novalidate
              data-api-url={apiUrl}
              data-form-token={formToken}
              data-campaign-code={campaignCode}
              data-gracias-path={graciasPath}
            >
              <div class="contact__field" data-field="nombre">
                <label for="nombre" class="contact__label">Nombre Completo</label>
                <input
                  type="text"
                  id="nombre"
                  name="nombre"
                  placeholder="e.g José Gutiérrez"
                  class="contact__input"
                  required
                />
              </div>

              <div class="contact__field" data-field="whatsapp">
                <label for="whatsapp" class="contact__label">Número de WhatsApp</label>
                <input
                  type="tel"
                  id="whatsapp"
                  name="whatsapp"
                  placeholder="999 999 999"
                  class="contact__input"
                  required
                />
              </div>

              <div class="contact__field" data-field="proveedor_china">
                <label for="proveedor" class="contact__label">¿Ya tienes tu proveedor en China?</label>
                <div class="contact__select-wrap">
                  <select id="proveedor" name="proveedor_china" class="contact__input contact__select" required>
                    <option value="" disabled selected>Selecciona una opción</option>
                    <option value="si">Sí, ya tengo proveedor</option>
                    <option value="no">No, necesito ayuda</option>
                    <option value="buscando">Estoy buscando proveedor</option>
                  </select>
                  <span class="contact__chevron" aria-hidden="true"></span>
                </div>
              </div>

              <button type="submit" class="contact__submit btn-primary font-epilogue font-bold text-white">
                Quiero importar
              </button>
              <p id="form-feedback" class="contact__feedback font-epilogue"></p>
            </form>
          </div>
          </div>
        </div>
      </div>

      <ul class="contact__trust">
        {
          trustItems.map((item) => (
            <li class="contact__trust-item font-epilogue">
              <img
                src={asset('/images/sections/10-contact/icon-check.svg')}
                alt=""
                class="contact__trust-icon"
                aria-hidden="true"
              />
              {item}
            </li>
          ))
        }
      </ul>
    </div>
  </div>
</section>

<style>
  .contact {
    background: #fff;
  }

  .contact__shell {
    width: min(100%, 100%);
    margin-inline: auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    border: 1px solid #fa4700;
    border-radius: var(--radius-ui);
    background: linear-gradient(180deg, #ff5410 0%, #ff6a29 100%);
    padding: clamp(1.25rem, calc(56 / 3973 * 100vw), 3.5rem)
      clamp(1rem, calc(40 / 3973 * 100vw), 2.5rem)
      clamp(1.5rem, calc(72 / 3973 * 100vw), 4rem);
  }

  @media (max-width: 767px) {
    .contact__shell {
      width: 100%;
    }
  }

  .contact__panel {
    width: min(100%, 95%);
    border: 1px solid rgba(250, 71, 0, 0.35);
    border-radius: var(--radius-ui);
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.08);
    background: #fff;
  }

  @media (max-width: 767px) {
    .contact__panel {
      width: 100%;
    }
  }

  .contact__body {
    background: #fff;
    padding-bottom: clamp(2rem, calc(120 / 3973 * 100vw), 5rem);
  }

  /* Figma 2030:12 — foto 1374×1134 | form ~1565px | copy bajo foto */
  .contact__grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr);
    grid-template-rows: auto auto auto;
  }

  @media (min-width: 1024px) {
    .contact__grid {
      grid-template-columns: minmax(0, 43.75%) minmax(0, 56.25%);
      grid-template-rows: auto 1fr;
      column-gap: clamp(0.25rem, calc(20 / 3973 * 100vw), 0.75rem);
    }
  }

  .contact__visual {
    position: relative;
    grid-column: 1;
    grid-row: 1;
    height: clamp(12rem, calc(1134 / 3973 * 100vw), 28.5rem);
    overflow: hidden;
    border-radius: var(--radius-ui) 0 0 0;
  }

  .contact__picture {
    position: absolute;
    inset: 0;
    display: block;
    width: 100%;
    height: 100%;
    line-height: 0;
  }

  .contact__photo,
  .contact__visual :global(.contact__photo) {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
  }

  @media (min-width: 1024px) {
    .contact__photo,
    .contact__visual :global(.contact__photo) {
      width: 122.48%;
      height: 124.39%;
      left: -15.9%;
      top: 0.02%;
      object-position: top center;
    }
  }

  .contact__visual-fade {
    position: absolute;
    inset-inline: 0;
    bottom: 0;
    height: 42%;
    z-index: 1;
    pointer-events: none;
    background: linear-gradient(180deg, rgba(255, 255, 255, 0) 0%, #fff 90%);
  }

  .contact__copy {
    grid-column: 1;
    grid-row: 2;
    padding: clamp(0.5rem, calc(28 / 3973 * 100vw), 1.25rem)
      clamp(1rem, calc(180 / 3973 * 100vw), 4.5rem)
      clamp(1.25rem, calc(48 / 3973 * 100vw), 2.5rem);
  }

  @media (min-width: 1024px) {
    .contact__copy {
      align-self: start;
      padding-top: clamp(0.35rem, calc(16 / 3973 * 100vw), 1rem);
    }
  }

  .contact__title {
    max-width: 12ch;
  }

  .contact__title-accent {
    display: inline;
  }

  .contact__subtitle {
    margin-top: clamp(0.5rem, calc(20 / 3973 * 100vw), 1.25rem);
    font-size: clamp(0.875rem, calc(78 / 3973 * 100vw), 2.15rem);
    line-height: 0.98;
    letter-spacing: -0.01em;
    max-width: 22ch;
  }

  .contact__form-wrap {
    grid-column: 1;
    grid-row: 3;
    padding: clamp(1rem, calc(32 / 3973 * 100vw), 2rem)
      clamp(1.75rem, calc(96 / 3973 * 100vw), 5rem)
      clamp(1rem, calc(32 / 3973 * 100vw), 2rem)
      clamp(1rem, calc(48 / 3973 * 100vw), 3rem);
  }

  @media (min-width: 1024px) {
    .contact__form-wrap {
      grid-column: 2;
      grid-row: 1 / span 2;
      align-self: stretch;
      padding-top: clamp(1.5rem, calc(319 / 3973 * 100vw), 5rem);
      padding-right: clamp(2rem, calc(140 / 3973 * 100vw), 6rem);
      padding-bottom: clamp(1rem, calc(40 / 3973 * 100vw), 2.5rem);
      padding-left: clamp(0.75rem, calc(32 / 3973 * 100vw), 2rem);
    }
  }

  .contact__form {
    display: flex;
    flex-direction: column;
    gap: clamp(1.25rem, calc(52 / 3973 * 100vw), 2.25rem);
  }

  @media (min-width: 1024px) {
    .contact__form {
      gap: clamp(1.5rem, calc(64 / 3973 * 100vw), 2.75rem);
    }
  }

  .contact__label {
    display: block;
    font-family: var(--font-epilogue);
    font-size: clamp(0.8125rem, calc(78 / 3973 * 100vw), 2.15rem);
    font-weight: 600;
    line-height: 1.26;
    color: #000;
    margin-bottom: clamp(0.35rem, calc(12 / 3973 * 100vw), 0.75rem);
  }

  .contact__input {
    width: 100%;
    min-height: clamp(2.75rem, calc(224 / 3973 * 100vw), 5.5rem);
    border-radius: var(--radius-ui);
    border: 1px solid #9c9c9c;
    background: #f6f6f6;
    padding: clamp(0.65rem, calc(20 / 3973 * 100vw), 1.25rem)
      clamp(0.875rem, calc(28 / 3973 * 100vw), 1.5rem);
    font-family: var(--font-epilogue);
    font-size: clamp(0.875rem, calc(78 / 3973 * 100vw), 2.15rem);
    line-height: 1.26;
    color: #000;
    outline: none;
  }

  .contact__input::placeholder {
    color: #9c9c9c;
  }

  .contact__input:focus {
    border-color: var(--color-probusiness-naranja);
    background: #fff;
  }

  .contact__select-wrap {
    position: relative;
  }

  .contact__select {
    appearance: none;
    padding-right: 2.75rem;
    color: #9c9c9c;
  }

  .contact__select:valid {
    color: #000;
  }

  .contact__chevron {
    position: absolute;
    right: clamp(0.875rem, calc(32 / 3973 * 100vw), 1.35rem);
    top: 50%;
    width: 0.55rem;
    height: 0.55rem;
    border-right: 2px solid #9c9c9c;
    border-bottom: 2px solid #9c9c9c;
    transform: translateY(-65%) rotate(45deg);
    pointer-events: none;
  }

  .contact__submit {
    width: 100%;
    margin-top: clamp(0.5rem, calc(20 / 3973 * 100vw), 1rem);
    border-radius: var(--radius-ui);
    font-size: clamp(1rem, calc(96 / 3973 * 100vw), 2.9rem);
    line-height: 1.26;
    padding-block: clamp(0.85rem, calc(44 / 3973 * 100vw), 1.75rem);
  }

  .contact__feedback {
    text-align: center;
    font-size: 0.875rem;
    color: rgba(0, 0, 0, 0.6);
    margin: 0;
  }

  .contact__trust {
    display: grid;
    gap: clamp(0.75rem, calc(24 / 3973 * 100vw), 1.25rem);
    width: 100%;
    margin: clamp(1.75rem, calc(64 / 3973 * 100vw), 3.5rem) 0 0;
    padding: 0 clamp(0.5rem, calc(24 / 3973 * 100vw), 1.5rem);
    list-style: none;
    background: transparent;
  }

  @media (min-width: 640px) {
    .contact__trust {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      column-gap: clamp(2rem, calc(120 / 3973 * 100vw), 6rem);
      row-gap: clamp(0.75rem, calc(28 / 3973 * 100vw), 1.5rem);
    }
  }

  .contact__trust-item {
    display: flex;
    align-items: center;
    gap: clamp(0.5rem, calc(16 / 3973 * 100vw), 0.75rem);
    font-size: clamp(0.8125rem, calc(78 / 3973 * 100vw), 2.15rem);
    font-weight: 400;
    line-height: 0.98;
    letter-spacing: -0.01em;
    color: #fff;
    justify-content: center;
  }

  .contact__trust-icon {
    width: clamp(1.125rem, calc(40 / 3973 * 100vw), 1.5rem);
    height: clamp(1.125rem, calc(40 / 3973 * 100vw), 1.5rem);
    flex-shrink: 0;
  }

  @media (max-width: 1023px) {
    .contact__visual {
      height: clamp(15rem, 62vw, 18.5rem);
    }

    .contact__visual-fade {
      height: 42%;
      background: linear-gradient(180deg, rgba(255, 255, 255, 0) 0%, #fff 90%);
    }

    .contact__title {
      max-width: none;
    }

    .contact__subtitle {
      font-size: clamp(1.05rem, 4.5vw, 1.4rem);
      max-width: none;
    }

    .contact__label {
      font-size: clamp(0.95rem, 4.1vw, 1.2rem);
    }

    .contact__input {
      font-size: clamp(1rem, 4.1vw, 1.2rem);
    }

    .contact__submit {
      font-size: clamp(1.15rem, 5vw, 1.5rem);
      box-shadow: 0 4px 20px 6px rgba(255, 84, 16, 0.42);
    }

    .contact__submit:hover {
      box-shadow: 0 6px 24px 8px rgba(255, 84, 16, 0.5);
    }

    .contact__feedback {
      font-size: 0.95rem;
    }

    .contact__trust-item {
      font-size: clamp(0.95rem, 4.1vw, 1.2rem);
      justify-content: flex-start;
    }

    .contact__trust {
      justify-items: start;
    }
  }
</style>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement | null;
  const feedback = document.getElementById('form-feedback');

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const apiUrl = form.dataset.apiUrl;
    const formToken = form.dataset.formToken;
    const campaignCode = form.dataset.campaignCode;
    const graciasPath = form.dataset.graciasPath ?? '/gracias';

    if (!apiUrl) {
      if (feedback) feedback.textContent = 'Formulario en modo demo — configura PUBLIC_LANDING_CONSOLIDADO_API_URL en .env';
      return;
    }

    const data = new FormData(form);
    try {
      const res = await fetch(apiUrl, {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          ...(formToken ? { 'X-Form-Token': formToken } : {}),
        },
        body: JSON.stringify({
          nombre: data.get('nombre'),
          whatsapp: data.get('whatsapp'),
          proveedor_china: data.get('proveedor_china'),
          campaign_code: campaignCode,
        }),
      });
      if (!res.ok) throw new Error();
      window.location.href = graciasPath;
    } catch {
      if (feedback) feedback.textContent = 'No pudimos enviar tu solicitud. Intenta de nuevo.';
    }
  });
</script>
