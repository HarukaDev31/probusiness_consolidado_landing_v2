---
import ResponsiveImage from './ResponsiveImage.astro';
import { asset } from '../lib/assets';

const stats = [
  {
    icon: '/images/sections/02-hero/icon-experiencia.svg',
    lines: [
      { text: '+10 años', bold: true },
      { text: ' de experiencia ', bold: false },
      { text: 'previa', bold: false, medium: true },
    ],
  },
  {
    icon: '/images/sections/02-hero/icon-seguridad.svg',
    lines: [
      { text: 'Seguridad en', bold: false },
      { text: 'todo el proceso', bold: true },
    ],
  },
  {
    icon: '/images/sections/02-hero/icon-entregas.svg',
    lines: [
      { text: 'Entregas', bold: false },
      { text: ' puntuales', bold: true },
    ],
  },
  {
    icon: '/images/sections/02-hero/icon-asesoria.svg',
    lines: [
      { text: 'Asesoría', bold: false },
      { text: 'personalizada', bold: true },
    ],
  },
];
---

<section id="inicio" class="hero">
  <div class="hero__orange" aria-hidden="true"></div>
  <ResponsiveImage
    src="/images/sections/02-hero/bg-fondo-carga.png"
    alt=""
    class="hero__fondo-carga hero__fondo-carga--desktop"
    sizes="55vw"
    aria-hidden="true"
    loading="eager"
  />

  <div class="hero__mobile-stage">
    <div class="hero__mobile-top">
      <a href="#inicio" class="hero__logo-wrap hero__logo-wrap--mobile" aria-label="ProBusiness — Inicio">
        <img
          src={asset('/images/sections/01-header/logo-mobile.svg')}
          alt="probusiness"
          class="hero__logo hero__logo--mobile"
          width="663"
          height="128"
          loading="eager"
        />
      </a>
    </div>
    <div class="hero__mobile-visual">
      <ResponsiveImage
        src="/images/sections/02-hero/bg-fondo-carga-mobile.png"
        alt=""
        class="hero__mobile-bg"
        sizes="100vw"
        loading="eager"
      />
    </div>
  </div>

  <div class="site-container hero__inner">
   
    </a>

    <div class="hero__grid">
      <div class="hero__content">
        <h1 class="hero__title font-sora font-medium text-white">
          <span class="block">Empieza hoy,</span>
          <span class="block">importa con nuestra</span>
          <span class="hero__title-row">
            <span class="font-semibold text-black">Carga Consolidada</span>
            <span class="badge-pro-hero">PRO</span>
          </span>
        </h1>

        <p class="hero__subtitle font-epilogue font-medium text-white">
          Productos desde China a Perú al mejor costo.
        </p>

        <div class="hero__stats">
          {
            stats.map((stat) => (
              <div class="hero__stat">
                <div class="hero__stat-icon-wrap">
                  <img src={asset('/images/sections/02-hero/ellipse.svg')} alt="" class="hero__stat-ellipse" aria-hidden="true" />
                  <img src={asset(stat.icon)} alt="" class="hero__stat-icon" aria-hidden="true" />
                </div>
                <p class="hero__stat-text font-epilogue text-white">
                  {stat.lines.map((line) => (
                    <span class:list={{ 'font-semibold': line.bold, 'font-medium': line.medium, 'font-normal': !line.bold && !line.medium }}>
                      {line.text}
                      <br />
                    </span>
                  ))}
                </p>
              </div>
            ))
          }
        </div>

        <a href="#contacto" class="btn-dark hero__cta font-epilogue font-bold text-white">Cotizar mi importación</a>

        <p class="hero__secure font-epilogue text-white flex flex-row items-center gap-2">
          <img src={asset('/images/sections/02-hero/icon-lock.svg')} alt="" class="hero__lock" aria-hidden="true" />
          Tu información 100% segura y confidencial
        </p>
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    overflow: hidden;
    padding-top: clamp(4.5rem, calc(172 / 3973 * 100vw), 6.5rem);
    padding-bottom: clamp(2rem, calc(120 / 3973 * 100vw), 4rem);
    min-height: clamp(32rem, calc(2202 / 3973 * 100vw), 52rem);
  }

  @media (max-width: 1023px) {
    .hero {
      display: flex;
      flex-direction: column;
      padding-top: 0;
      padding-bottom: 0;
      min-height: auto;
    }
  }

  .hero__orange {
    position: absolute;
    inset: 0;
    background: #ff5410;
    z-index: 0;
  }

  .hero__fondo-carga--desktop,
  .hero :global(.hero__fondo-carga--desktop) {
    display: none;
  }

  @media (min-width: 1024px) {
    .hero__fondo-carga--desktop,
    .hero :global(.hero__fondo-carga--desktop) {
      display: block;
      position: absolute;
      top: 0;
      right: 0;
      width: min(69%, calc(2737 / 3973 * 100vw));
      height: 100%;
      object-fit: cover;
      object-position: right top;
      z-index: 1;
      pointer-events: none;
    }
  }

  .hero__mobile-stage {
    display: none;
  }

  .hero__mobile-top {
    display: none;
  }

  .hero__mobile-visual {
    position: relative;
    overflow: hidden;
  }

  @media (max-width: 1023px) {
    .hero__mobile-stage {
      display: flex;
      flex-direction: column;
      width: 100%;
      height: 500px;
      flex-shrink: 0;
      background: #ff5410;
      z-index: 1;
    }

    .hero__mobile-top {
      display: flex;
      align-items: flex-end;
      justify-content: center;
      flex-shrink: 0;
      height: 100px;
      padding-bottom: clamp(0.75rem, 3vw, 1.25rem);
      background: #ff5410;
      position: relative;
      z-index: 3;
    }

    .hero__mobile-visual {
      flex: 1;
      min-height: 0;
    }

    .hero__logo-wrap--mobile {
      display: flex;
      justify-content: center;
      margin: 0;
    }

    .hero__logo-wrap--desktop {
      display: none;
    }

    .hero__logo--mobile {
      display: block;
      width: clamp(9rem, 42vw, 12.5rem);
      height: auto;
    }
  }

  .hero__mobile-visual::before {
    content: '';
    position: absolute;
    inset: 0;
    z-index: 2;
    pointer-events: none;
    background: linear-gradient(
      180deg,
      #ff5410 0%,
      rgba(255, 84, 16, 0.55) 22%,
      rgba(255, 84, 16, 0.15) 45%,
      transparent 65%
    );
  }

  .hero__mobile-visual::after {
    content: '';
    position: absolute;
    inset: 0;
    z-index: 2;
    pointer-events: none;
    background: linear-gradient(
      90deg,
      #ff5410 0%,
      rgba(255, 84, 16, 0.65) 14%,
      rgba(255, 84, 16, 0.15) 38%,
      transparent 58%
    );
  }

  .hero__mobile-bg,
  .hero__mobile-visual :global(.hero__mobile-bg),
  .hero__mobile-visual :global(picture) {
    display: block;
    width: 100%;
    height: 100%;
  }

  .hero__mobile-bg,
  .hero__mobile-visual :global(.hero__mobile-bg) {
    object-fit: cover;
    object-position: center 55%;
  }

  @media (min-width: 1024px) {
    .hero__mobile-stage {
      display: none;
    }
  }

  .hero__inner {
    position: relative;
    z-index: 2;
    padding-top: clamp(3.5rem, calc(120 / 3973 * 100vw), 5rem);
  }

  @media (max-width: 1023px) {
    .hero__inner {
      position: relative;
      z-index: 2;
      flex: 1;
      min-height: 400px;
      padding-top: 1.25rem;
      padding-bottom: 1.5rem;
      background: #ff5410;
    }
  }

  .hero__logo-wrap {
    display: flex;
    justify-content: center;
    margin-bottom: clamp(1rem, calc(32 / 3973 * 100vw), 2rem);
  }

  .hero__logo,
  .hero__logo-wrap :global(.hero__logo) {
    height: clamp(2.5rem, calc(97 / 3973 * 100vw), 4.5rem);
    width: auto;
  }

  @media (min-width: 1024px) {
    .hero__logo-wrap :global(.hero__logo) {
      filter: brightness(0) invert(1);
    }
  }

  .hero__grid {
    display: grid;
    align-items: center;
    gap: clamp(1.5rem, calc(48 / 3973 * 100vw), 3rem);
  }

  @media (max-width: 1023px) {
    .hero__grid {
      text-align: left;
    }

    .hero__content {
      display: flex;
      flex-direction: column;
      align-items: flex-start;
      width: 100%;
    }

    .hero__title {
      text-align: left;
      align-self: flex-start;
      width: 100%;
    }

    .hero__title-row {
      justify-content: flex-start;
    }

    .hero__subtitle {
      text-align: left;
      align-self: flex-start;
    }

    .hero__stat-icon-wrap {
      width: clamp(2.35rem, 18vw, 3rem);
      height: clamp(2.35rem, 18vw, 3rem);
    }

    .hero__secure {
      font-size: clamp(0.6875rem, 3vw, 0.8125rem);
      justify-content: center;
      align-self: center;
      width: 100%;
      text-align: center;
    }
  }

  @media (min-width: 1024px) {
    .hero__grid {
      grid-template-columns: minmax(0, 48%) minmax(0, 52%);
    }
  }

  .hero__title {
    line-height: 1.03;
    letter-spacing: -0.04em;
  }

  @media (max-width: 1023px) {
    .hero__title {
      font-size: clamp(1.54rem, 6.62vw, 2.21rem);
    }
  }

  @media (min-width: 1024px) {
    .hero__title {
      font-size: clamp(1.35rem, calc(140 / 3973 * 100vw), 4.23rem);
    }
  }

  .hero__title-row {
    display: inline-flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
    gap: 0.35rem 0.5rem;
    margin-top: 0.15em;
  }

  @media (min-width: 1024px) {
    .hero__title-row {
      justify-content: flex-start;
    }
  }

  .badge-pro-hero {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: var(--radius-ui);
    background: #000;
    font-family: var(--font-sora);
    font-weight: 600;
    letter-spacing: -0.06em;
    color: var(--color-probusiness-naranja);
  }

  @media (max-width: 1023px) {
    .badge-pro-hero {
      min-width: 3.21rem;
      min-height: 1.78rem;
      border-radius: var(--radius-ui);
      padding-inline: 0.62rem;
      font-size: 1.02rem;
    }
  }

  @media (min-width: 1024px) {
    .badge-pro-hero {
      min-width: clamp(3.5rem, calc(237 / 3973 * 100vw), 9rem);
      min-height: clamp(1.75rem, calc(128 / 3973 * 100vw), 5rem);
      padding-inline: clamp(0.5rem, calc(20 / 3973 * 100vw), 1.25rem);
      font-size: clamp(1rem, calc(96 / 3973 * 100vw), 2.9rem);
    }
  }

  .hero__subtitle {
    margin-top: clamp(0.75rem, calc(24 / 3973 * 100vw), 1.5rem);
    line-height: 1.26;
  }

  @media (max-width: 1023px) {
    .hero__subtitle {
      font-size: clamp(0.8125rem, 3.6vw, 1rem);
    }
  }

  @media (min-width: 1024px) {
    .hero__subtitle {
      font-size: clamp(0.625rem, calc(65 / 3973 * 100vw), 1.8rem);
    }
  }

  .hero__stats {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: clamp(0.35rem, calc(12 / 3973 * 100vw), 0.75rem);
    margin-top: clamp(1.25rem, calc(56 / 3973 * 100vw), 3.5rem);
    width: 100%;
  }

  @media (min-width: 640px) and (max-width: 1023px) {
    .hero__stats {
      gap: clamp(0.5rem, calc(16 / 3973 * 100vw), 1rem);
    }
  }

  @media (min-width: 1024px) {
    .hero__stats {
      gap: clamp(0.75rem, calc(20 / 3973 * 100vw), 1.5rem);
      margin-top: clamp(1.5rem, calc(80 / 3973 * 100vw), 3.5rem);
    }
  }

  .hero__stat {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }

  .hero__stat-icon-wrap {
    position: relative;
    width: clamp(2.75rem, calc(315 / 3973 * 100vw), 8rem);
    height: clamp(2.75rem, calc(315 / 3973 * 100vw), 8rem);
    margin-bottom: clamp(0.25rem, calc(8 / 3973 * 100vw), 0.75rem);
  }

  .hero__stat-ellipse {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }

  .hero__stat-icon {
    position: absolute;
    top: 50%;
    left: 50%;
    width: 50%;
    height: 50%;
    transform: translate(-50%, -50%);
    object-fit: contain;
  }

  .hero__stat-text {
    font-size: clamp(0.5rem, calc(50 / 3973 * 100vw), 1.51rem);
    line-height: 0.93;
    text-shadow: 0 4px 38px rgba(0, 0, 0, 0.5);
    margin-top: 0.35em;
  }

  @media (max-width: 1023px) {
    .hero__stat-text {
      white-space: normal;
      font-size: clamp(0.5625rem, 2.75vw, 0.6875rem);
      line-height: 1.12;
    }

    .hero__stat-text span {
      display: inline;
    }

    .hero__stat-text br {
      display: none;
    }
  }

  @media (min-width: 1024px) {
    .hero__stat-text {
      white-space: nowrap;
      margin-top: 0.5em;
    }
  }

  .hero__stat-text span {
    display: inline;
  }

  .hero__cta {
    display: inline-flex;
    width: 100%;
    max-width: min(100%, calc(1659 / 3973 * 100vw));
    align-items: center;
    justify-content: center;
    margin-top: clamp(1.25rem, calc(64 / 3973 * 100vw), 2.5rem);
  }

  @media (max-width: 1023px) {
    .hero__cta {
      width: 90%;
      max-width: 90%;
      align-self: center;
      margin-top: 1.5rem;
      border-radius: var(--radius-ui);
    }
  }

  @media (min-width: 1024px) {
    .hero__cta {
      width: auto;
      min-width: min(100%, calc(1659 / 3973 * 100vw));
    }
  }

  .hero__secure {
    margin-top: clamp(1rem, calc(32 / 3973 * 100vw), 1.75rem);
    font-size: clamp(0.625rem, calc(48 / 3973 * 100vw), 1.45rem);
    line-height: 1.26;
  }

  @media (min-width: 1024px) {
    .hero__secure {
      justify-content: center;
    }
  }

  .hero__lock {
    width: clamp(1rem, calc(43 / 3973 * 100vw), 1.75rem);
    height: clamp(1rem, calc(43 / 3973 * 100vw), 1.75rem);
    flex-shrink: 0;
  }
</style>
