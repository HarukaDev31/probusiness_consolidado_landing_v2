---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Gracias | ProBusiness Carga Consolidada" description="Recibimos tu solicitud. Un asesor te contactará pronto.">
  <main class="flex min-h-screen items-center justify-center bg-black px-6 text-center">
    <div>
      <h1 class="font-sora text-3xl font-semibold text-white lg:text-5xl">¡Gracias por tu interés!</h1>
      <p class="mt-4 font-epilogue text-lg text-white/80 lg:text-xl">
        Un asesor de ProBusiness te contactará pronto para cotizar tu importación.
      </p>
      <a href="/" class="btn-primary mt-8 inline-block px-8 py-4 font-epilogue font-bold text-white">
        Volver al inicio
      </a>
    </div>
  </main>
</Layout>
